{
  "name": "color-bandit",
  "version": "1.0.0",
  "description": "Library for calculating average color and color palette from images.",
  "type": "module",
  "sideEffects": false,
  "main": "dist/color-bandit.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "webpack && yarn copy:types",
    "copy:types": "cp src/index.d.ts dist/index.d.ts",
    "watch": "webpack --watch",
    "dev": "webpack --watch --mode development",
    "lint": "eslint src/js/main.js tests/**/*.js",
    "lint:fix": "eslint src/js/main.js tests/**/*.js --fix",
    "format": "prettier --write \"src/**/*.js\" \"**/*.md\" \"*.config.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"**/*.md\" \"*.config.js\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "playwright test",
    "test:browser:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "color",
    "palette",
    "dominant color",
    "average color",
    "image processing"
  ],
  "author": "Johnny Dev",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.17",
    "babel-loader": "^10.1.1",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jsdom": "^29.1.1",
    "playwright": "^1.52.0",
    "prettier": "^3.8.3",
    "terser-webpack-plugin": "^5.6.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.0",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  }
}

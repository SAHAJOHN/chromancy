{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "noEmit": true
  },
  "include": ["src/**/*.d.ts", "tests/**/*.js", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
